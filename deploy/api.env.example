# Copy to api.env on VPS and fill secrets.
#
# Docker compose also sets:
# - PORT=8080
# - DATABASE_URL=postgresql://redflow:${POSTGRES_PASSWORD}@postgres:5432/redflow

PUBLIC_ORIGIN=https://redflow.online

# Auth
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars________________
JWT_REFRESH_SECRET=change_me_refresh_secret
REFRESH_COOKIE_NAME=rf_refresh
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=2592000

# S3 (Hetzner Object Storage)
S3_ENDPOINT=https://fsn1.your-objectstorage.endpoint
S3_REGION=fsn1
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_BUCKET_AVATARS=avatars
S3_BUCKET_MESSENGER_MEDIA=messenger-media

# Web Push (optional)
# VAPID keys are required for browser push subscriptions
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Default subject if not set: PUBLIC_ORIGIN
VAPID_SUBJECT=

