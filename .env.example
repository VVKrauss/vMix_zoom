# Локальная разработка: скопируйте в .env и при необходимости измените.
# Production: значения по умолчанию заданы в .env.production (коммитится в репозиторий).
#
# Редкая отладка: подробные логи useRoom (socket/mediasoup) и рендер-трейс мессенджера — только в dev.
# VITE_DEV_TRACE=true
#
# Базовый URL бэкенда (без слэша в конце): Socket.IO и REST /api/frontend/*.
# Без правильного URL сборка подставит origin страницы → wss://redflow.online/socket.io/ и обрыв.
VITE_SIGNALING_URL=https://s.redflow.online

# API (HTTP + /ws). В РФ некоторые провайдеры/DPI режут прямой доступ к api2 → используем фолбэк через VPS-прокси.
VITE_API_BASE=https://api2.redflow.online
# Если PRIMARY недоступен (probe /api/health, таймаут ~3s) — запросы уйдут сюда и выбор закэшируется на 1 час.
VITE_API_FALLBACK=https://proxy.redflow.online
VITE_DEFAULT_ROOM=test

# Supabase (RedFlow project)
VITE_SUPABASE_URL=https://dbhrmaabotdaagmiuzum.supabase.co
VITE_SUPABASE_ANON_KEY=
#
# Опционально: HTTPS reverse proxy на ваш VPS к тому же проекту Supabase (те же пути, что у *.supabase.co).
# В дашборде появится переключатель «Прокси для базы»; mediasoup / signaling не затрагиваются.
# На прокси нужны /rest/v1, /auth/v1, /realtime/v1, /storage/v1 и upgrade для WebSocket (Realtime).
# VITE_SUPABASE_PROXY_ORIGIN=https://sb-proxy.example.com
# По умолчанию для новых браузеров включить прокси, пока пользователь явно не выключит в дашборде:
# VITE_SUPABASE_PROXY_DEFAULT=false
#
# Web Push (публичный ключ VAPID; пара генерируется: npx web-push generate-vapid-keys).
# Должен совпадать с секретом VAPID_PUBLIC_KEY в Edge Function send-dm-webpush.
# VITE_VAPID_PUBLIC_KEY=
#
# Миграции CLI (`npx supabase db push --db-url ...`): URI Postgres из Dashboard → Settings → Database
# (Session mode / Direct). В локальный `.env` — не коммитить.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.dbhrmaabotdaagmiuzum.supabase.co:5432/postgres
#
# После подтверждения почты — /auth/email-confirmed (см. src/config/authUrls.ts).
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://redflow.online
#   Redirect URLs (добавить оба):
#     https://redflow.online/auth/email-confirmed
#     http://localhost:5173/auth/email-confirmed

# Опционально: тот же секрет, что API_SECRET на signaling — админские REST (настройки, рестарт).
# Предпочтительное имя переменной. Попадает в клиентский бандл — только для закрытых админ-сборок.
# VITE_ADMIN_API_SECRET=
#
# Обратная совместимость: если VITE_ADMIN_API_SECRET не задан, используется:
# VITE_SERVER_RESTART_SECRET=
