# ──────────────────────────────────────────────────────
# vMix Streamer — environment variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────

# Public IP of your VPS (used by mediasoup WebRTC ICE candidates)
ANNOUNCED_IP=1.2.3.4

# Backend HTTP port
PORT=3000

# SRT ports for vMix (one per participant slot)
# vMix Input → SRT → srt://ANNOUNCED_IP:9001  (participant 1)
#                  → srt://ANNOUNCED_IP:9002  (participant 2)  ...
SRT_BASE_PORT=9001

# Maximum simultaneous participants
MAX_PEERS=10

# mediasoup worker count (recommend: number of CPU cores, max 4)
MEDIASOUP_WORKER_COUNT=2

# WebRTC UDP port range (must be opened in firewall)
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# RTP base port for localhost FFmpeg pipes (no firewall needed)
RTP_BASE_PORT=20000
