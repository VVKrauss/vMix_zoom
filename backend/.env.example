PORT=8080
PUBLIC_ORIGIN=https://redflow.online

# Postgres on VPS (docker compose)
DATABASE_URL=postgresql://redflow:CHANGE_ME@127.0.0.1:5432/redflow

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_ISSUER=redflow
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=2592000
REFRESH_COOKIE_NAME=rf_refresh

# Hetzner Object Storage (S3)
S3_ENDPOINT=https://hel1.your-objectstorage.com
S3_REGION=hel1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=redflow-media

